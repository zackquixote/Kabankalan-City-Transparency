#--------------------------------------------------------------------
# OPENMODEL API  (required for the Chatbot module)
# Copy this file to .env and fill in the values below.
#--------------------------------------------------------------------

# Your API key from https://openmodel.ai
# OPENMODEL_API_KEY = YOUR_OPENMODEL_API_KEY_HERE

# The model identifier to use.
# OpenAI-style models  → use /v1/responses endpoint (auto-detected)
#   e.g. gpt-4o, mistral-large-latest, meta-llama/Llama-3-70b-instruct
# Anthropic-style models → use /v1/messages endpoint (auto-detected when model starts with "claude")
#   e.g. claude-opus-4-5, claude-3-haiku-20240307
# OPENMODEL_MODEL = gpt-4o

